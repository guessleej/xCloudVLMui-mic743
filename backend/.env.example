# ══════════════════════════════════════════════════════════════════════
# xCloudVLMui Platform [bot-mic743] — backend/.env.example
# 硬體：Advantech MIC-743 / NVIDIA Jetson Thor AGX (Blackwell, 128GB)
# ══════════════════════════════════════════════════════════════════════

# ── 基礎 ─────────────────────────────────────────────────────────────
APP_NAME=xCloudVLMui Platform [bot-mic743]
DEBUG=false
SECRET_KEY=change-me-to-random-32-char-string!!

# ── LLM（容器內 llama-cpp CUDA，非 Ollama）────────────────────────────
# MIC-743 使用 Blackwell GPU 在容器內直接推論，無需外部 Ollama
LLM_BASE_URL=http://llama-cpp:8080
LLM_MODEL=gemma-4-e4b-it
LLM_CTX_SIZE=131072
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── 嵌入模型 ──────────────────────────────────────────────────────────
EMBED_MODEL_URL=http://llama-cpp:8080
EMBED_MODEL=nomic-embed-text

# ── 資料庫 ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/xcloudvlm.db
CHROMA_PERSIST_DIR=/data/chroma
UPLOAD_DIR=/app/uploads

# ── OCR ───────────────────────────────────────────────────────────────
OCR_ENGINE=vlm

# ── MQTT ──────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_ENABLED=true

# ── HuggingFace（model-init 下載 GGUF 用）────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_REPO=bartowski/google_gemma-4-e4b-it-GGUF
# MIC-743 128GB RAM 建議 Q4_K_M（高精度）；Q6_K 亦可
MODEL_FILE=gemma-4-e4b-it-Q4_K_M.gguf

# ── VLM WebUI ─────────────────────────────────────────────────────────
VLM_WEBUI_URL=http://vlm-webui:8090

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3200","http://localhost:8780","http://localhost"]
